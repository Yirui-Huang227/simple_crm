<div class="customer-card">
  <% if customer.image.attached? %>
    <%= image_tag customer.image.variant(resize_to_limit: [150, 150]) %>
  <% end %>
  <h3><%= customer.full_name %></h3>
  <p>Phone: <%= customer.phone %></p>
  <p>Email: <%= customer.email.presence || "N/A" %></p>
  <p><%= customer.notes %></p>
</div>